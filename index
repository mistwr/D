<script>
// ══════════════════════════════════════════
// LUMIN AI — Claude AI Backend
// ══════════════════════════════════════════

const MODELOS = {
  '30': { nome:'LUMIN AI 3.0', model:'claude-sonnet-4-20250514', cor:'var(--c)', label:'v3.0', lblClass:'lbl-30', emoji:'⚡' },
  'pro': { nome:'LUMIN AI Pro 10.0', model:'claude-sonnet-4-20250514', cor:'var(--cp)', label:'Pro v10.0', lblClass:'lbl-pro', emoji:'🔮' }
};

const SYSTEM_PROMPT = `És o LUMIN AI, assistente de emergência médica em Portugal.
Respondes SEMPRE em português europeu, de forma clara, direta e prática.
Em emergências: dás passos numerados e concisos. Sem asteriscos nem markdown.
Especialidades: RCP, hemorragia, AVC, enfarte, engasgamento, queimaduras, fraturas, hipotermia, choque, envenenamento, parto de emergência.
Lembras sempre: ligar 112 em emergência grave.
Máximo 200 palavras por resposta salvo pedido explícito.
Tratas o utilizador com calma e clareza.`;

let modeloAtivo = '30';
let historico = [];
let userLat = null, userLng = null;
let mapObj = null, mapMarker = null;
let voiceRec = null, aEscutar = false;

const HIST_KEY = 'lumin_hist';
const MODEL_KEY = 'lumin_modelo';

// ── ARRANQUE ──────────────────────────────
window.addEventListener('load', () => {
  setTimeout(() => {
    const spl = document.getElementById('splash');
    spl.style.transition = 'opacity .5s';
    spl.style.opacity = '0';
    setTimeout(() => {
      spl.style.display = 'none';
      const guardado = localStorage.getItem(MODEL_KEY);
      if (guardado && MODELOS[guardado]) {
        modeloAtivo = guardado;
        lancarApp();
      } else {
        document.getElementById('sel-screen').style.display = 'block';
      }
    }, 500);
  }, 2300);
});

// ── SELEÇÃO ───────────────────────────────
window.selectModel = function(ver) {
  document.querySelectorAll('.model-card').forEach(c => c.classList.remove('sel'));
  document.getElementById('card-' + ver).classList.add('sel');
  modeloAtivo = ver;
  const btn = document.getElementById('btn-avancar');
  btn.classList.add('show');
  btn.textContent = '➤ Entrar com ' + MODELOS[ver].nome;
};

window.iniciarApp = function() {
  if (!modeloAtivo) return;
  localStorage.setItem(MODEL_KEY, modeloAtivo);
  lancarApp();
};

function lancarApp() {
  document.getElementById('sel-screen').style.display = 'none';
  document.getElementById('app').classList.add('show');
  const m = MODELOS[modeloAtivo];
  document.getElementById('h-ver').textContent = m.label;
  document.getElementById('h-ver').style.color = m.cor;
  document.getElementById('msg-lbl-boas').textContent = '⬡ ' + m.nome;
  document.getElementById('msg-lbl-boas').className = 'lbl ' + m.lblClass;
  setBarIA('ok', '✅ ' + m.nome + ' · Claude AI · Pronto');
  // Restaura histórico
  try { historico = JSON.parse(localStorage.getItem(HIST_KEY) || '[]'); } catch(e) { historico = []; }
  atualizarMemBadge();
  if (historico.length > 0) {
    historico.slice(-6).forEach(h => addMsg(h.content, h.role === 'user' ? 'u' : 'a'));
  }
  construirMedico();
  construirCrises();
  construirKit();
  iniciarGPS();
}

window.trocarModelo = function() {
  if (!confirm('Trocar de modelo?')) return;
  localStorage.removeItem(MODEL_KEY);
  location.reload();
};

// ── ENVIAR MENSAGEM ───────────────────────
window.enviar = async function() {
  const el = document.getElementById('ci');
  const txt = el.value.trim();
  if (!txt || document.getElementById('send').disabled) return;
  el.value = '';
  addMsg(txt, 'u');
  document.getElementById('send').disabled = true;
  setBarIA('think', '🧠 A pensar...');

  historico.push({ role: 'user', content: txt });
  guardarHist();
  atualizarMemBadge();

  const gpsCtx = userLat
    ? `[Localização GPS do utilizador: ${userLat.toFixed(5)}, ${userLng.toFixed(5)} — Portugal]`
    : '[GPS não disponível]';

  const dotDiv = addMsg('', 'a', true);

  try {
    const msgs = [
      { role: 'user', content: SYSTEM_PROMPT + '\n' + gpsCtx + '\n\nPrimeira mensagem: Apresenta-te brevemente.' },
      { role: 'assistant', content: 'Olá! Sou o LUMIN AI, assistente de emergência. Como posso ajudar?' },
      ...historico.slice(-12)
    ];

    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: MODELOS[modeloAtivo].model,
        max_tokens: 1000,
        system: SYSTEM_PROMPT + '\n' + gpsCtx,
        messages: historico.slice(-12)
      })
    });

    const data = await res.json();
    if (dotDiv) dotDiv.remove();

    if (data.content && data.content[0]) {
      const resp = data.content[0].text;
      addMsg(resp, 'a');
      historico.push({ role: 'assistant', content: resp });
      guardarHist();
      atualizarMemBadge();
      setBarIA('ok', '✅ ' + MODELOS[modeloAtivo].nome + ' · Claude AI');
    } else {
      throw new Error(data.error?.message || 'Sem resposta');
    }
  } catch(err) {
    if (dotDiv) dotDiv.remove();
    // Fallback offline
    const resp = respostaOffline(txt);
    addMsg(resp, 'a');
    historico.push({ role: 'assistant', content: resp });
    guardarHist();
    atualizarMemBadge();
    setBarIA('err', '⚠️ Modo offline · ' + (err.message || 'Erro de ligação'));
  }

  document.getElementById('send').disabled = false;
};

// ── FALLBACK OFFLINE ──────────────────────
const KW = {
  rcp:['rcp','paragem','cardíac','coração parou','não respira','desmaiou','inconsciente','ressuscit'],
  hemor:['sangue','sangramento','hemorragia','ferida','corte','sangra'],
  avc:['avc','derrame','boca torta','face torta','paralisia','fala arrastada'],
  enfarte:['enfarte','ataque cardíaco','dor no peito'],
  engasgo:['engasgad','sufoc','obstrução','não consegue respirar'],
  queimadura:['queimadr','escaldão','calor extremo'],
  fratura:['frat','osso partido','torci','luxação'],
  hipotermia:['hipotermia','congelamento','frio extremo'],
  choque:['choque','pálido suado','pressão baixa'],
  veneno:['veneno','intoxicação','engoliu produto','tóxico'],
};

function respostaOffline(txt) {
  const t = txt.toLowerCase();
  for (const [id, kws] of Object.entries(KW)) {
    if (kws.some(k => t.includes(k))) {
      const p = PROTOS.find(x => x.id === id);
      if (p) return `${p.icon} ${p.titulo}\n\n` +
        p.passos.map((s,i) => `${i+1}. ${s.t}\n${s.d}`).join('\n\n') +
        (p.aviso ? `\n\n⚠️ ${p.aviso}` : '') +
        '\n\n📞 Liga agora: 112';
    }
  }
  if (t.includes('112')) return '📞 Liga imediatamente para o 112 — Emergência Nacional.';
  return 'Descreve melhor a situação. Usa os separadores 🩺 Médico ou 🆘 SOS.\n\n📞 Emergência: 112';
}

// ── UI CHAT ───────────────────────────────
function addMsg(txt, role, streaming = false) {
  const box = document.getElementById('chat-box');
  const m = MODELOS[modeloAtivo] || MODELOS['30'];
  const div = document.createElement('div');
  div.className = 'msg ' + role;
  if (streaming) {
    div.innerHTML = `<div class="lbl ${m.lblClass}">⬡ ${m.nome}</div><div class="typing"><span></span><span></span><span></span></div>`;
    box.appendChild(div); box.scrollTop = box.scrollHeight; return div;
  }
  if (role === 'a') {
    div.innerHTML = `<div class="lbl ${m.lblClass}">⬡ ${m.nome}</div>` + txt.replace(/\n/g,'<br>');
  } else {
    div.textContent = txt;
  }
  box.appendChild(div); box.scrollTop = box.scrollHeight; return div;
}

function setBarIA(cls, txt) {
  const b = document.getElementById('ai-bar');
  b.className = cls; b.textContent = txt;
}

// ── MEMÓRIA ───────────────────────────────
function guardarHist() {
  if (historico.length > 20) historico = historico.slice(-20);
  localStorage.setItem(HIST_KEY, JSON.stringify(historico));
}
function atualizarMemBadge() {
  document.getElementById('mem-count').textContent =
    `Memória: ${historico.length} mensagem${historico.length !== 1 ? 's' : ''}`;
}
window.limparMemoria = function() {
  if (!confirm('Limpar toda a memória?')) return;
  historico = [];
  localStorage.removeItem(HIST_KEY);
  document.getElementById('chat-box').innerHTML = '';
  addMsg('Memória apagada. Nova sessão iniciada.', 'a');
  atualizarMemBadge();
};

// ── GPS ───────────────────────────────────
function iniciarGPS() {
  if (!navigator.geolocation) return;
  navigator.geolocation.watchPosition(pos => {
    userLat = pos.coords.latitude; userLng = pos.coords.longitude;
    const acc = Math.round(pos.coords.accuracy);
    document.getElementById('loc-txt').textContent = `GPS ativo (±${acc}m)`;
    document.getElementById('loc-coord').textContent = `${userLat.toFixed(4)}, ${userLng.toFixed(4)}`;
    document.getElementById('h-gps').textContent = `📍 ${userLat.toFixed(3)}, ${userLng.toFixed(3)}`;
    document.getElementById('sos-coords').textContent = `📍 ${userLat.toFixed(6)}, ${userLng.toFixed(6)}`;
    if (mapObj) {
      mapObj.setView([userLat, userLng], 15);
      if (mapMarker) mapMarker.setLatLng([userLat, userLng]);
      else mapMarker = L.marker([userLat, userLng]).addTo(mapObj).bindPopup('<b>A tua posição</b>').openPopup();
      buscarProximos();
    }
  }, () => {
    document.getElementById('loc-txt').textContent = 'GPS: permissão negada';
  }, { enableHighAccuracy: true, timeout: 15000, maximumAge: 10000 });
}

// ── MAPA ──────────────────────────────────
let camadaSatelite = false;
let tileLayer = null;
let todosMarkers = [];

const MARKER_CORES = {
  hospital:   { cor:'#ff3b3b', emoji:'🏥' },
  fire_station:{ cor:'#ff8c00', emoji:'🚒' },
  pharmacy:   { cor:'#00ff9d', emoji:'💊' },
  police:     { cor:'#00d4ff', emoji:'🚔' },
};

function criarIcone(tipo) {
  const cfg = MARKER_CORES[tipo] || { cor:'#fff', emoji:'📍' };
  return L.divIcon({
    className: '',
    html: `<div style="background:${cfg.cor};width:32px;height:32px;border-radius:50% 50% 50% 0;
      transform:rotate(-45deg);border:2px solid #000;display:flex;align-items:center;justify-content:center;
      box-shadow:0 2px 8px rgba(0,0,0,.5)">
      <span style="transform:rotate(45deg);font-size:14px">${cfg.emoji}</span></div>`,
    iconSize:[32,32], iconAnchor:[16,32], popupAnchor:[0,-34]
  });
}

function criarIconeUser() {
  return L.divIcon({
    className: '',
    html: `<div style="width:18px;height:18px;border-radius:50%;background:#00d4ff;
      border:3px solid #fff;box-shadow:0 0 0 4px rgba(0,212,255,.3),0 2px 8px rgba(0,0,0,.5)"></div>`,
    iconSize:[18,18], iconAnchor:[9,9]
  });
}

function iniciarMapa() {
  if (mapObj) return;
  mapObj = L.map('map', { zoomControl: false, attributionControl: false });
  L.control.zoom({ position: 'topleft' }).addTo(mapObj);
  tileLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 });
  tileLayer.addTo(mapObj);
  mapObj.setView(userLat ? [userLat, userLng] : [38.7169, -9.1399], userLat ? 16 : 12);
  if (userLat) {
    mapMarker = L.marker([userLat, userLng], { icon: criarIconeUser(), zIndexOffset: 1000 }).addTo(mapObj);
    buscarProximos();
  }
}

window.centrarMapa = function() {
  if (!mapObj) return;
  if (userLat) mapObj.setView([userLat, userLng], 16);
};

window.toggleCamada = function() {
  if (!mapObj) return;
  camadaSatelite = !camadaSatelite;
  mapObj.removeLayer(tileLayer);
  const url = camadaSatelite
    ? 'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}'
    : 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png';
  tileLayer = L.tileLayer(url, { maxZoom: 19 });
  tileLayer.addTo(mapObj);
  tileLayer.bringToBack();
  document.getElementById('btn-camada').textContent = camadaSatelite ? '🛰' : '🗺';
};

function buscarProximos() {
  if (!userLat) return;
  const grid = document.getElementById('near-grid');
  grid.innerHTML = '<div class="near-item" style="grid-column:1/-1;color:var(--sub)">🔍 A procurar...</div>';

  // Remove markers antigos
  todosMarkers.forEach(m => mapObj && mapObj.removeLayer(m));
  todosMarkers = [];

  const q = `[out:json][timeout:10];(
    node["amenity"="hospital"](around:5000,${userLat},${userLng});
    node["amenity"="fire_station"](around:5000,${userLat},${userLng});
    node["amenity"="pharmacy"](around:2000,${userLat},${userLng});
    node["amenity"="police"](around:5000,${userLat},${userLng});
  );out body;`;

  fetch('https://overpass-api.de/api/interpreter', { method:'POST', body:q, signal:AbortSignal.timeout(9000) })
    .then(r => r.json())
    .then(data => {
      const found = {};
      // Agrupa por tipo, guarda todos
      const todos = {};
      data.elements.forEach(el => {
        const t = el.tags.amenity;
        if (!todos[t]) todos[t] = [];
        todos[t].push(el);
        if (!found[t]) found[t] = el; // guarda o 1º (mais perto)
      });

      // Adiciona markers no mapa para todos os pontos
      data.elements.forEach(el => {
        if (!el.lat) return;
        const m = L.marker([el.lat, el.lon], { icon: criarIcone(el.tags.amenity) }).addTo(mapObj);
        const d = haversine(userLat, userLng, el.lat, el.lon);
        const nome = el.tags.name || MARKER_CORES[el.tags.amenity]?.emoji || el.tags.amenity;
        m.bindPopup(`
          <div style="font-family:'Courier New',monospace;min-width:160px">
            <div style="font-weight:bold;color:#000;font-size:.82rem">${nome}</div>
            <div style="color:#555;font-size:.7rem;margin:.2rem 0">${d<1?(d*1000).toFixed(0)+'m':d.toFixed(1)+'km'} de distância</div>
            <a href="https://www.google.com/maps/dir/?api=1&destination=${el.lat},${el.lon}"
              target="_blank"
              style="display:block;background:#00d4ff;color:#000;text-align:center;padding:.3rem;
              border-radius:5px;font-size:.72rem;font-weight:bold;text-decoration:none;margin-top:.4rem">
              🗺 Como Chegar
            </a>
          </div>
        `);
        todosMarkers.push(m);
      });

      // Atualiza grid inferior
      const icons = { hospital:'🏥', fire_station:'🚒', pharmacy:'💊', police:'🚔' };
      grid.innerHTML = '';
      Object.entries(icons).forEach(([tipo, ico]) => {
        const el = found[tipo];
        const item = document.createElement('div');
        item.className = 'near-item';
        if (el) {
          const d = haversine(userLat, userLng, el.lat, el.lon);
          const nome = el.tags.name || tipo;
          item.innerHTML = `${ico} <span style="flex:1"><b style="font-size:.65rem">${nome.slice(0,16)}</b><br>
            <small style="color:var(--c)">${d<1?(d*1000).toFixed(0)+'m':d.toFixed(1)+'km'}</small></span>
            <span style="font-size:.6rem;color:var(--cg);cursor:pointer" onclick="window.open('https://www.google.com/maps/dir/?api=1&destination=${el.lat},${el.lon}','_blank')">▶ IR</span>`;
          item.onclick = () => { mapObj.setView([el.lat, el.lon], 17); const mk = todosMarkers.find(m => { const ll=m.getLatLng(); return ll.lat===el.lat&&ll.lng===el.lon; }); if(mk) mk.openPopup(); };
        } else {
          item.innerHTML = `${ico} <span style="color:var(--sub)">Não encontrado</span>`;
        }
        grid.appendChild(item);
      });
    })
    .catch(() => {
      grid.innerHTML = '<div class="near-item" style="grid-column:1/-1;color:var(--sub);font-size:.62rem">⚠️ Sem ligação. Usa os contactos SOS.</div>';
    });
}

function haversine(a, b, c, d) {
  const R=6371, x=(c-a)*Math.PI/180, y=(d-b)*Math.PI/180;
  const h=Math.sin(x/2)**2+Math.cos(a*Math.PI/180)*Math.cos(c*Math.PI/180)*Math.sin(y/2)**2;
  return R*2*Math.atan2(Math.sqrt(h),Math.sqrt(1-h));
}

// ── TABS ──────────────────────────────────
window.tab = function(id) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('on'));
  document.getElementById('p-map').classList.remove('on');
  document.querySelectorAll('nav button').forEach(b => b.classList.remove('on'));
  const tabs = ['ai','map','med','sos','kit'];
  const idx = tabs.indexOf(id);
  if (idx >= 0) document.querySelectorAll('nav button')[idx].classList.add('on');
  if (id === 'map') {
    document.getElementById('p-map').classList.add('on');
    setTimeout(() => { iniciarMapa(); if (mapObj) mapObj.invalidateSize(); }, 80);
  } else {
    const p = document.getElementById('p-' + id);
    if (p) p.classList.add('on');
  }
};

// ── VOZ ───────────────────────────────────
window.toggleVoz = function() {
  if (!('webkitSpeechRecognition' in window || 'SpeechRecognition' in window)) {
    addMsg('⚠️ Reconhecimento de voz não disponível neste browser.', 'a'); return;
  }
  if (aEscutar) { voiceRec.stop(); return; }
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  voiceRec = new SR(); voiceRec.lang = 'pt-PT';
  voiceRec.onresult = e => { document.getElementById('ci').value = e.results[0][0].transcript; enviar(); };
  voiceRec.onend = () => { aEscutar = false; document.getElementById('vbtn').classList.remove('on'); };
  voiceRec.start(); aEscutar = true; document.getElementById('vbtn').classList.add('on');
};

// ── SOS ───────────────────────────────────
window.abrirSOS = function() {
  document.getElementById('sos-ov').classList.add('show');
  if (navigator.vibrate) navigator.vibrate([200,100,200,100,200]);
};
window.fecharSOS = function() { document.getElementById('sos-ov').classList.remove('show'); };
window.partilharLocalizacao = function() {
  if (!userLat) { alert('Localização não disponível.'); return; }
  const url = `https://maps.google.com/?q=${userLat},${userLng}`;
  const txt = `🆘 EMERGÊNCIA · LUMIN AI\nLocalização: ${userLat.toFixed(6)}, ${userLng.toFixed(6)}\n${url}`;
  if (navigator.share) navigator.share({ title:'LUMIN AI · SOS', text:txt, url });
  else navigator.clipboard.writeText(txt).then(() => alert('Localização copiada!'));
};

// ══════════════════════════════════════════
// DADOS OFFLINE
// ══════════════════════════════════════════
const PROTOS = [
  { id:'rcp', icon:'💓', titulo:'RCP — Reanimação Cardiopulmonar', sub:'Paragem cardíaca', passos:[
    {t:'SEGURANÇA + AJUDA', d:'Confirma segurança. Toca nos ombros. Não responde: liga 112 em viva-voz.'},
    {t:'30 COMPRESSÕES', d:'Mãos cruzadas no centro do peito. Comprime 5-6cm a 100-120x/min.'},
    {t:'2 INSUFLAÇÕES', d:'Inclina cabeça, levanta queixo, aperta nariz. 2 sopros de 1 segundo.'},
    {t:'REPETIR 30:2', d:'Ciclo contínuo até o socorro chegar ou a vítima recuperar.'},
