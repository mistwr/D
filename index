<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>LUMIN AI</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
:root{
  --c:#00d4ff;--cg:#00ff9d;--cr:#ff3b3b;--cy:#ffd600;--cp:#a855f7;
  --bg:#000;--bg2:#06101c;--bg3:#0c1820;
  --glass:rgba(0,212,255,.07);--border:rgba(0,212,255,.13);
  --text:#ddf4ff;--sub:#4e8fa3;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{height:100%;background:#000;color:var(--text);font-family:'Courier New',monospace;overflow:hidden}

/* SPLASH */
#splash{position:fixed;inset:0;background:#000;z-index:9999;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.5rem}
.spl-hex{font-size:4rem;color:var(--c);animation:glow 2s infinite}
.spl-name{font-size:1.6rem;letter-spacing:4px;color:var(--c);font-weight:bold}
.spl-tag{font-size:.68rem;color:var(--sub);letter-spacing:2px}
.spl-bar{width:210px;height:2px;background:#0d1825;border-radius:2px;margin-top:1.2rem;overflow:hidden}
.spl-fill{height:100%;background:linear-gradient(90deg,var(--c),var(--cg));width:0;animation:fill 2.2s forwards}
@keyframes fill{to{width:100%}}
@keyframes glow{0%,100%{text-shadow:0 0 20px var(--c)}50%{text-shadow:0 0 60px var(--c),0 0 120px #0af}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* MODELO SELECT */
#sel-screen{display:none;position:fixed;inset:0;background:var(--bg);
  z-index:8000;overflow-y:auto;padding:1.4rem 1rem 3rem}
.sel-header{text-align:center;margin-bottom:1.5rem}
.sel-title{font-size:1.1rem;color:var(--c);font-weight:bold;letter-spacing:2px;margin-top:.3rem}
.sel-sub{font-size:.68rem;color:var(--sub);margin-top:.25rem;line-height:1.5}
.model-card{border-radius:14px;padding:1.1rem;margin-bottom:.9rem;cursor:pointer;
  transition:all .2s;border:2px solid var(--border);background:var(--bg3);position:relative;overflow:hidden}
.model-card.sel{border-color:var(--c);box-shadow:0 0 20px rgba(0,212,255,.15)}
.model-card.pro.sel{border-color:var(--cp);box-shadow:0 0 20px rgba(168,85,247,.15)}
.mc-version{position:absolute;top:.8rem;right:.8rem;font-size:.6rem;
  font-weight:bold;padding:.2rem .55rem;border-radius:20px;border:1px solid}
.v30{color:#00d4ff;border-color:rgba(0,212,255,.4);background:rgba(0,212,255,.1)}
.vpro{color:#a855f7;border-color:rgba(168,85,247,.4);background:rgba(168,85,247,.1)}
.mc-top{display:flex;align-items:flex-start;gap:.7rem;margin-bottom:.7rem}
.mc-icon{font-size:2.2rem;line-height:1}
.mc-name{font-size:1rem;font-weight:bold;color:var(--c);letter-spacing:.5px}
.model-card.pro .mc-name{color:var(--cp)}
.mc-base{font-size:.62rem;color:var(--sub);margin-top:.1rem}
.mc-bars{margin-bottom:.7rem}
.mc-bar-row{display:flex;align-items:center;gap:.5rem;margin-bottom:.3rem}
.mc-bar-label{font-size:.6rem;color:var(--sub);width:65px;flex-shrink:0}
.mc-bar-track{flex:1;height:5px;background:#0d1825;border-radius:3px;overflow:hidden}
.mc-bar-fill{height:100%;border-radius:3px}
.fill-speed{background:linear-gradient(90deg,var(--c),#00aacc)}
.fill-inteli{background:linear-gradient(90deg,var(--cg),#00cc77)}
.fill-mem{background:linear-gradient(90deg,var(--cy),#cc9900)}
.mc-pills{display:flex;flex-wrap:wrap;gap:.3rem;margin-bottom:.5rem}
.pill{font-size:.6rem;padding:.18rem .48rem;border-radius:10px;
  background:var(--bg2);border:1px solid var(--border);color:var(--text)}
.pill.green{border-color:rgba(0,255,157,.3);color:var(--cg)}
.pill.blue{border-color:rgba(0,212,255,.3);color:var(--c)}
.pill.purple{border-color:rgba(168,85,247,.3);color:var(--cp)}
.pill.yellow{border-color:rgba(255,214,0,.3);color:var(--cy)}
.mc-desc{font-size:.7rem;color:var(--sub);line-height:1.55}
.mc-btn{width:100%;margin-top:.75rem;padding:.65rem;border-radius:8px;
  font-size:.8rem;font-weight:bold;cursor:pointer;border:none;transition:.2s}
.btn-30{background:rgba(0,212,255,.15);color:var(--c);border:1px solid rgba(0,212,255,.4)}
.model-card.sel .btn-30{background:var(--c);color:#000}
.btn-pro{background:rgba(168,85,247,.15);color:var(--cp);border:1px solid rgba(168,85,247,.4)}
.model-card.sel .btn-pro{background:var(--cp);color:#fff}
.sel-compare{background:var(--bg3);border:1px solid var(--border);border-radius:10px;
  padding:.7rem;margin-bottom:1rem;font-size:.65rem;color:var(--sub);line-height:1.6;text-align:center}
.sel-compare strong{color:var(--c)}
#btn-avancar{width:100%;padding:.8rem;background:var(--c);color:#000;border:none;
  border-radius:10px;font-size:.9rem;font-weight:bold;cursor:pointer;display:none;margin-top:.5rem}
#btn-avancar.show{display:block}

/* APP */
#app{display:none;flex-direction:column;height:100vh}
#app.show{display:flex}
header{background:var(--bg2);border-bottom:1px solid var(--border);
  padding:.55rem .9rem;display:flex;align-items:center;gap:.4rem;flex-shrink:0}
.h-dot{width:7px;height:7px;border-radius:50%;background:var(--cg);
  box-shadow:0 0 8px var(--cg);animation:pulse 2.5s infinite;flex-shrink:0}
.h-logo{font-size:.9rem;font-weight:bold;color:var(--c);letter-spacing:1px}
.h-ver{font-size:.52rem;padding:.1rem .35rem;border-radius:8px;
  border:1px solid var(--border);color:var(--c);background:var(--glass);cursor:pointer}
.h-space{flex:1}
#h-gps{font-size:.53rem;color:var(--sub);max-width:80px;text-align:right;line-height:1.3}
#sos-btn{background:var(--cr);color:#fff;border:none;padding:.35rem .65rem;
  border-radius:6px;font-size:.68rem;font-weight:bold;cursor:pointer}
nav{background:var(--bg2);display:flex;border-bottom:1px solid var(--border);flex-shrink:0}
nav button{flex:1;padding:.55rem .1rem;background:none;border:none;color:var(--sub);
  font-size:.56rem;cursor:pointer;border-bottom:2px solid transparent;transition:.15s;
  display:flex;flex-direction:column;align-items:center;gap:1px}
nav button .ni{font-size:.95rem}
nav button.on{color:var(--c);border-bottom-color:var(--c)}
.panel{display:none;flex:1;overflow-y:auto;padding:.7rem;flex-direction:column;gap:.5rem}
.panel.on{display:flex}
#p-map{display:none;flex:1;flex-direction:column;padding:0;position:relative}
#p-map.on{display:flex}
#map{flex:1;min-height:0}
.map-ov{position:absolute;bottom:.6rem;left:.5rem;right:.5rem;z-index:1000;
  background:rgba(0,5,15,.92);border:1px solid var(--border);border-radius:10px;
  padding:.65rem;backdrop-filter:blur(12px)}
.map-ov h3{color:var(--c);font-size:.72rem;margin-bottom:.4rem}
.near-grid{display:grid;grid-template-columns:1fr 1fr;gap:.3rem}
.near-item{background:var(--bg3);border:1px solid var(--border);border-radius:7px;
  padding:.38rem;display:flex;align-items:center;gap:.3rem;font-size:.63rem;cursor:pointer}

/* CHAT */
#chat-box{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:.4rem;margin-bottom:.4rem;min-height:0}
.msg{max-width:88%;padding:.45rem .6rem;border-radius:10px;font-size:.72rem;
  line-height:1.65;word-break:break-word}
.msg.u{background:rgba(0,212,255,.11);border:1px solid rgba(0,212,255,.22);
  align-self:flex-end;color:#fff}
.msg.a{background:var(--bg3);border:1px solid var(--border);align-self:flex-start}
.msg.a .lbl{font-size:.57rem;margin-bottom:.2rem;font-weight:bold;letter-spacing:.5px}
.lbl-30{color:var(--c)}
.lbl-pro{color:var(--cp)}
.typing span{display:inline-block;width:5px;height:5px;border-radius:50%;
  background:var(--c);margin:0 2px;animation:td .9s infinite}
.typing span:nth-child(2){animation-delay:.2s}
.typing span:nth-child(3){animation-delay:.4s}
@keyframes td{0%,80%,100%{transform:translateY(0)}40%{transform:translateY(-5px)}}
#ai-bar{font-size:.58rem;text-align:center;padding:.12rem 0;min-height:.9rem;
  flex-shrink:0;color:var(--sub)}
#ai-bar.ok{color:var(--cg)}
#ai-bar.err{color:var(--cr)}
#ai-bar.think{color:var(--cy);animation:pulse .8s infinite}
.inp-row{display:flex;gap:.3rem;flex-shrink:0}
#ci{flex:1;background:var(--bg3);border:1px solid var(--border);border-radius:8px;
  color:var(--text);padding:.45rem .6rem;font-size:.76rem;font-family:inherit;
  resize:none;max-height:75px}
#ci:focus{outline:none;border-color:var(--c)}
#send{background:var(--c);color:#000;border:none;border-radius:8px;
  padding:.45rem .7rem;cursor:pointer;font-weight:bold;font-size:.8rem;flex-shrink:0}
#send:disabled{background:#0d1825;color:#2a4a5a;cursor:not-allowed}
#vbtn{background:var(--bg3);border:1px solid var(--border);border-radius:8px;
  padding:.45rem .5rem;cursor:pointer;font-size:.95rem;flex-shrink:0}
#vbtn.on{border-color:var(--cr);background:rgba(255,59,59,.15);animation:pulse .7s infinite}
.mem-bar{background:rgba(168,85,247,.06);border:1px solid rgba(168,85,247,.2);
  border-radius:8px;padding:.32rem .6rem;font-size:.6rem;
  display:flex;align-items:center;gap:.4rem;color:var(--sub)}
.mem-bar .mi{color:var(--cp)}
.mem-bar .mc2{margin-left:auto;color:var(--cr);cursor:pointer;font-size:.58rem}
.loc-badge{background:var(--glass);border:1px solid var(--border);border-radius:7px;
  padding:.32rem .55rem;font-size:.62rem;display:flex;align-items:center;gap:.35rem}
.sec{color:var(--sub);font-size:.6rem;letter-spacing:1.5px;text-transform:uppercase;
  padding:.15rem 0;border-bottom:1px solid var(--border);margin-bottom:.3rem;flex-shrink:0}
.card{background:var(--bg3);border:1px solid var(--border);border-radius:10px;
  padding:.7rem;cursor:pointer;flex-shrink:0}
.card.open{border-color:var(--cg)}
.ch{display:flex;align-items:center;gap:.4rem;margin-bottom:.25rem}
.ci2{font-size:1.15rem}
.ct{font-size:.78rem;font-weight:bold;color:var(--c)}
.card.open .ct{color:var(--cg)}
.cs{font-size:.63rem;color:var(--sub)}
.cb{display:none;font-size:.7rem;line-height:1.6;color:var(--text)}
.card.open .cb{display:block}
.step{background:var(--bg2);border-left:2px solid var(--c);border-radius:0 5px 5px 0;
  padding:.38rem .58rem;margin-top:.3rem}
.step strong{color:var(--cy);display:block;font-size:.63rem;margin-bottom:.1rem}
.warn{background:rgba(255,59,59,.07);border:1px solid rgba(255,59,59,.25);
  border-radius:7px;padding:.38rem .58rem;font-size:.67rem;color:var(--cr);margin-top:.3rem}
.call-btn{margin-top:.45rem;background:var(--cr);color:#fff;border:none;
  padding:.38rem;border-radius:6px;cursor:pointer;font-size:.7rem;width:100%}
.sos-grid{display:grid;grid-template-columns:1fr 1fr;gap:.45rem}
.sos-card{background:var(--bg3);border:1px solid var(--border);border-radius:10px;
  padding:.7rem;text-align:center;text-decoration:none;display:block;cursor:pointer}
.sos-card:active{border-color:var(--cr);background:rgba(255,59,59,.08)}
.sos-num{font-size:1.1rem;font-weight:bold;color:var(--cr)}
.sos-lbl{font-size:.6rem;color:var(--sub);margin-top:.12rem}
.sos-desc{font-size:.57rem;color:var(--text);margin-top:.08rem}
.kit-item{display:flex;align-items:center;gap:.55rem;padding:.38rem 0;
  border-bottom:1px solid var(--border);font-size:.7rem}
.kit-item input{width:15px;height:15px;accent-color:var(--cg);flex-shrink:0}
.kit-item.done label{text-decoration:line-through;color:var(--sub)}
#sos-ov{display:none;position:fixed;inset:0;background:rgba(180,0,0,.15);
  z-index:9000;flex-direction:column;align-items:center;justify-content:center;
  backdrop-filter:blur(8px)}
#sos-ov.show{display:flex}
.sos-big{font-size:5rem;animation:glow 1s infinite}
.sos-sub{color:var(--cr);font-size:1rem;margin:.4rem 0}
.sos-coords{font-size:.68rem;color:var(--sub);text-align:center;max-width:260px;margin-bottom:.8rem}
.sos-acts{display:flex;flex-direction:column;gap:.45rem;width:85%;max-width:290px}
.sos-act{padding:.7rem;border-radius:9px;font-size:.82rem;font-weight:bold;
  cursor:pointer;border:none;display:flex;align-items:center;gap:.5rem;justify-content:center}
.sos-close{margin-top:1rem;background:var(--bg3);border:1px solid var(--cr);
  color:var(--cr);padding:.45rem 1.3rem;border-radius:8px;cursor:pointer;font-size:.82rem}
::-webkit-scrollbar{width:2px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
</style>
</head>
<body>

<!-- SPLASH -->
<div id="splash">
  <div class="spl-hex">⬡</div>
  <div class="spl-name">LUMIN AI</div>
  <div class="spl-tag">PLATAFORMA DE EMERGÊNCIA · PORTUGAL</div>
  <div class="spl-bar"><div class="spl-fill"></div></div>
</div>

<!-- SELEÇÃO MODELO -->
<div id="sel-screen">
  <div class="sel-header">
    <div style="font-size:1.8rem;color:var(--c)">⬡</div>
    <div class="sel-title">ESCOLHE O TEU LUMIN AI</div>
    <div class="sel-sub">Powered by Claude · Responde instantaneamente · Sem download</div>
  </div>

  <div class="model-card" id="card-30" onclick="selectModel('30')">
    <span class="mc-version v30">v3.0</span>
    <div class="mc-top">
      <div class="mc-icon">⚡</div>
      <div class="mc-info">
        <div class="mc-name">LUMIN AI 3.0</div>
        <div class="mc-base">Motor: Claude Sonnet · Rápido · Preciso</div>
      </div>
    </div>
    <div class="mc-bars">
      <div class="mc-bar-row"><span class="mc-bar-label">⚡ Velocidade</span><div class="mc-bar-track"><div class="mc-bar-fill fill-speed" style="width:90%"></div></div><span style="font-size:.58rem;color:var(--c);margin-left:.3rem">Rápido</span></div>
      <div class="mc-bar-row"><span class="mc-bar-label">🧠 Inteligência</span><div class="mc-bar-track"><div class="mc-bar-fill fill-inteli" style="width:85%"></div></div><span style="font-size:.58rem;color:var(--cg);margin-left:.3rem">Alta</span></div>
      <div class="mc-bar-row"><span class="mc-bar-label">📝 Contexto</span><div class="mc-bar-track"><div class="mc-bar-fill fill-mem" style="width:70%"></div></div><span style="font-size:.58rem;color:var(--cy);margin-left:.3rem">Amplo</span></div>
    </div>
    <div class="mc-pills">
      <span class="pill green">✅ Sem download</span>
      <span class="pill blue">⚡ Resposta rápida</span>
      <span class="pill">🩺 Médico completo</span>
      <span class="pill">🧠 Memória de contexto</span>
    </div>
    <div class="mc-desc">Assistente de emergência com IA avançada. Protocolos médicos, GPS, mapa e contactos de emergência PT. Responde em segundos.</div>
    <button class="mc-btn btn-30">Selecionar LUMIN AI 3.0</button>
  </div>

  <div class="model-card pro" id="card-pro" onclick="selectModel('pro')">
    <span class="mc-version vpro">Pro v10.0</span>
    <div class="mc-top">
      <div class="mc-icon">🔮</div>
      <div class="mc-info">
        <div class="mc-name">LUMIN AI Pro 10.0</div>
        <div class="mc-base">Motor: Claude Opus · Máxima capacidade</div>
      </div>
    </div>
    <div class="mc-bars">
      <div class="mc-bar-row"><span class="mc-bar-label">⚡ Velocidade</span><div class="mc-bar-track"><div class="mc-bar-fill fill-speed" style="width:70%"></div></div><span style="font-size:.58rem;color:var(--c);margin-left:.3rem">Normal</span></div>
      <div class="mc-bar-row"><span class="mc-bar-label">🧠 Inteligência</span><div class="mc-bar-track"><div class="mc-bar-fill fill-inteli" style="width:98%"></div></div><span style="font-size:.58rem;color:var(--cg);margin-left:.3rem">Máxima</span></div>
      <div class="mc-bar-row"><span class="mc-bar-label">📝 Contexto</span><div class="mc-bar-track"><div class="mc-bar-fill fill-mem" style="width:95%"></div></div><span style="font-size:.58rem;color:var(--cy);margin-left:.3rem">Extenso</span></div>
    </div>
    <div class="mc-pills">
      <span class="pill green">✅ Sem download</span>
      <span class="pill purple">🔮 Mais capaz</span>
      <span class="pill">💬 Análise profunda</span>
      <span class="pill">🧬 Diagnóstico avançado</span>
    </div>
    <div class="mc-desc">Máxima inteligência para situações complexas. Análise aprofundada, contexto extenso, respostas mais detalhadas e precisas.</div>
    <button class="mc-btn btn-pro">Selecionar LUMIN AI Pro 10.0</button>
  </div>

  <div class="sel-compare">
    💡 <strong>Não tens a certeza?</strong><br>
    Para a maioria das emergências, o <strong>LUMIN AI 3.0</strong> é mais rápido.<br>
    O <strong>Pro 10.0</strong> é melhor para análises complexas.
  </div>
  <button id="btn-avancar" onclick="iniciarApp()">➤ Entrar no LUMIN AI</button>
  <div style="font-size:.58rem;color:var(--sub);text-align:center;margin-top:.5rem;line-height:1.5">
    Powered by Claude AI · Requer ligação à internet
  </div>
</div>

<!-- APP -->
<div id="app">
  <header>
    <div class="h-dot"></div>
    <div class="h-logo">⬡ LUMIN AI</div>
    <div class="h-ver" id="h-ver" onclick="trocarModelo()">v3.0</div>
    <div class="h-space"></div>
    <div id="h-gps">📍 A localizar...</div>
    <button id="sos-btn" onclick="abrirSOS()">🆘 SOS</button>
  </header>
  <nav>
    <button class="on" onclick="tab('ai')"><span class="ni">🤖</span>IA</button>
    <button onclick="tab('map')"><span class="ni">🗺️</span>Mapa</button>
    <button onclick="tab('med')"><span class="ni">🩺</span>Médico</button>
    <button onclick="tab('sos')"><span class="ni">🆘</span>SOS</button>
    <button onclick="tab('kit')"><span class="ni">🎒</span>Kit</button>
  </nav>

  <!-- PAINEL IA -->
  <div class="panel on" id="p-ai">
    <div class="loc-badge">
      <span>📍</span>
      <span id="loc-txt">A aguardar GPS...</span>
      <span style="margin-left:auto;font-size:.62rem;color:var(--c)" id="loc-coord"></span>
    </div>
    <div class="mem-bar">
      <span class="mi">🧠</span>
      <span id="mem-count">Memória: 0 mensagens</span>
      <span class="mc2" onclick="limparMemoria()">🗑 Limpar</span>
    </div>
    <div id="chat-box">
      <div class="msg a">
        <div class="lbl" id="msg-lbl-boas">⬡ LUMIN AI</div>
        Olá! Estou pronto para ajudar em situações de emergência.<br><br>
        🩺 Protocolos médicos completos<br>
        📍 Localização GPS em tempo real<br>
        🆘 Contactos de emergência PT<br>
        🗺️ Pontos de socorro próximos<br><br>
        <strong>Descreve o que está a acontecer:</strong>
      </div>
    </div>
    <div id="ai-bar" class="ok">✅ LUMIN AI ativo · Claude AI</div>
    <div class="inp-row">
      <button id="vbtn" onclick="toggleVoz()">🎤</button>
      <textarea id="ci" rows="1" placeholder="Ex: pessoa desmaiou, não respira..."
        onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();enviar()}"></textarea>
      <button id="send" onclick="enviar()">➤</button>
    </div>
  </div>

  <!-- PAINEL MAPA -->
  <div id="p-map">
    <div id="map"></div>
    <!-- controles flutuantes -->
    <div style="position:absolute;top:.5rem;right:.5rem;z-index:1000;display:flex;flex-direction:column;gap:.3rem">
      <button onclick="centrarMapa()" style="background:var(--bg2);border:1px solid var(--border);color:var(--c);border-radius:8px;padding:.45rem .55rem;cursor:pointer;font-size:.9rem">📍</button>
      <button onclick="toggleCamada()" id="btn-camada" style="background:var(--bg2);border:1px solid var(--border);color:var(--sub);border-radius:8px;padding:.45rem .55rem;cursor:pointer;font-size:.75rem">🗺</button>
    </div>
    <!-- barra inferior -->
    <div class="map-ov">
      <h3>📍 Pontos de Emergência Próximos</h3>
      <div class="near-grid" id="near-grid">
        <div class="near-item">📡 <span>Ativa o GPS para ver</span></div>
      </div>
    </div>
  </div>

  <!-- PAINEL MÉDICO -->
  <div class="panel" id="p-med">
    <div class="sec">🩺 Protocolos de Emergência</div>
  </div>

  <!-- PAINEL SOS -->
  <div class="panel" id="p-sos">
    <div class="sec">📞 Contactos de Emergência · Portugal</div>
    <div class="sos-grid">
